generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id           String   @id @default(cuid())
  name         String
  email        String
  whatsapp     String?
  businessType String?  @map("business_type")
  message      String
  source       String   @db.VarChar(20) // "form", "chat"
  utmSource    String?  @map("utm_source") @db.VarChar(100)
  utmMedium    String?  @map("utm_medium") @db.VarChar(100)
  utmCampaign  String?  @map("utm_campaign") @db.VarChar(200)
  landingPage  String?  @map("landing_page") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([source])
  @@index([createdAt])
  @@map("leads")
}
