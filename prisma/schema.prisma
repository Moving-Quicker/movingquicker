generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id           String   @id @default(cuid())
  name         String
  email        String
  whatsapp     String?
  businessType String?  @map("business_type")
  message      String
  source       String   @db.VarChar(20) // "form", "chat"
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([source])
  @@index([createdAt])
  @@map("leads")
}
